# SecBleau environment variables
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://secbleau:secbleau@db:5432/secbleau

# Netatmo (optional — public weather stations)
# Register at https://dev.netatmo.com to get credentials
NETATMO_CLIENT_ID=
NETATMO_CLIENT_SECRET=

# App settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Cloudflare Tunnel token (required for production tunnel via cloudflared)
# Get from: Cloudflare Dashboard → Zero Trust → Tunnels → your tunnel → Configure
CLOUDFLARE_TUNNEL_TOKEN=
