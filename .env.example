# SecBleau environment variables
# Copy to .env and fill in values — never commit .env to version control

# ── Database credentials ─────────────────────────────────────────────────────
# Change DB_PASSWORD to a strong random value in production.
# Used by both the PostgreSQL container and the API connection string.
DB_USER=secbleau
DB_PASSWORD=changeme
DB_NAME=secbleau
DATABASE_URL=postgresql+asyncpg://secbleau:changeme@db:5432/secbleau

# ── Netatmo (optional — public weather stations) ─────────────────────────────
# Register at https://dev.netatmo.com to get credentials
NETATMO_CLIENT_ID=
NETATMO_CLIENT_SECRET=

# ── App settings ─────────────────────────────────────────────────────────────
# Set to "development" locally to enable SQL echo and API docs (/api/docs)
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── CORS — comma-separated list of allowed frontend origins ──────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Cloudflare Tunnel (required only for production tunnel via cloudflared) ───
# Get from: Cloudflare Dashboard → Zero Trust → Tunnels → your tunnel → Configure
CLOUDFLARE_TUNNEL_TOKEN=
