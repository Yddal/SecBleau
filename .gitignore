# Environment — never commit real credentials
.env
.env.local
.env.*.local
docker-compose.override.yml

# Python
__pycache__/
*.py[cod]
.venv/
backend/.venv/
*.egg-info/

# Boolder data cache — downloaded automatically, don't commit large GeoJSON files
backend/data/boolder-data/*.geojson
backend/data/boolder-data/.version

# Node
frontend/node_modules/
frontend/.svelte-kit/
frontend/build/

# Docker
*.log

# Database backups — kept locally, never committed
backups/
